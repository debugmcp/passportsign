{
  "name": "passportsign",
  "version": "0.0.0",
  "private": true,
  "description": "Sigstore-adjacent personhood attestations binding GitHub accounts to passport-holding humans, logged to the public Sigstore Rekor transparency log.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "cli": "pnpm --filter @passportsign/cli run cli"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
